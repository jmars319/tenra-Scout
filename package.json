{
  "name": "tenra-scout",
  "private": true,
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmars319/tenra-Scout.git"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.21.1"
  },
  "scripts": {
    "bootstrap": "node ./scripts/bootstrap.mjs",
    "db:prepare": "node --no-warnings --experimental-strip-types --experimental-specifier-resolution=node ./scripts/prepare-postgres.ts",
    "db:import:local-runs": "node --no-warnings --experimental-strip-types --experimental-specifier-resolution=node ./scripts/import-local-runs.ts",
    "check:env": "node ./scripts/check-env.mjs",
    "check:packages": "node ./scripts/check-packages.mjs",
    "clean:local": "node ./scripts/clean-local.mjs",
    "clean:local:full": "node ./scripts/clean-local.mjs --full",
    "dev:web": "pnpm --filter @scout/webapp dev",
    "dev:worker": "pnpm --filter @scout/webapp run worker",
    "dev:all": "node ./scripts/dev-all.mjs",
    "dev:desktop": "pnpm --filter @scout/desktopapp dev",
    "start:desktop": "pnpm --filter @scout/desktopapp start",
    "launch:desktop": "pnpm --filter @scout/desktopapp run launch:mac",
    "install:desktop": "pnpm --filter @scout/desktopapp run install:mac",
    "dev:mobile": "pnpm --filter @scout/mobileapp dev",
    "dev:both": "node ./scripts/dev-both.mjs",
    "worker:start": "pnpm --filter @scout/webapp run worker",
    "build:web": "pnpm --filter @scout/webapp build",
    "build:desktop": "pnpm --filter @scout/desktopapp build",
    "build:mobile": "pnpm --filter @scout/mobileapp build",
    "check:desktop-package": "pnpm --filter @scout/desktopapp run check:package",
    "check:desktop-release-env": "pnpm --filter @scout/desktopapp run check:release-env",
    "qa:desktop-install": "pnpm --filter @scout/desktopapp run qa:install",
    "qa:operator": "node ./scripts/qa-operator-checklist.mjs",
    "package:desktop": "pnpm --filter @scout/desktopapp run dist:mac",
    "package:desktop:release": "pnpm --filter @scout/desktopapp run dist:mac:release",
    "lint": "pnpm exec eslint .",
    "typecheck": "pnpm --filter \"./packages/**\" --if-present typecheck && pnpm --filter \"./apps/**\" --if-present typecheck",
    "verify:acquisition": "node --no-warnings --experimental-strip-types --experimental-specifier-resolution=node ./scripts/verify-acquisition.ts",
    "verify:providers": "node --no-warnings --experimental-strip-types --experimental-specifier-resolution=node ./scripts/verify-providers.ts",
    "verify:candidates": "node --no-warnings --experimental-strip-types --experimental-specifier-resolution=node ./scripts/verify-candidates.ts",
    "verify:comparison": "node --no-warnings --experimental-strip-types --experimental-specifier-resolution=node ./scripts/verify-market-comparison.ts",
    "verify:leads": "node --no-warnings --experimental-strip-types --experimental-specifier-resolution=node ./scripts/verify-leads.ts",
    "verify:outreach": "node --no-warnings --experimental-strip-types --experimental-specifier-resolution=node ./scripts/verify-outreach.ts",
    "verify:persistence": "node --no-warnings --experimental-strip-types --experimental-specifier-resolution=node ./scripts/verify-persistence.ts",
    "verify:queue": "node --no-warnings --experimental-strip-types --experimental-specifier-resolution=node ./scripts/verify-queue.ts",
    "verify:run-controls": "node --no-warnings --experimental-strip-types --experimental-specifier-resolution=node ./scripts/verify-run-controls.ts",
    "verify:handoffs": "node ./scripts/validate-handoffs.mjs && node --no-warnings --experimental-strip-types --experimental-specifier-resolution=node ./scripts/verify-handoff-receipts.ts",
    "verify:runtime-contract": "node ./scripts/verify-app-runtime-manifest.mjs",
    "verify:http-smoke": "node --no-warnings --experimental-strip-types --experimental-specifier-resolution=node ./scripts/verify-http-smoke.ts",
    "verify:ui-smoke": "pnpm run verify:http-smoke",
    "verify:web": "pnpm run lint && pnpm run typecheck && pnpm run verify:acquisition && pnpm run verify:providers && pnpm run verify:candidates && pnpm run verify:comparison && pnpm run verify:leads && pnpm run verify:outreach && pnpm run verify:persistence && pnpm run verify:queue && pnpm run verify:run-controls && pnpm run build:web",
    "verify:desktop": "pnpm --filter @scout/desktopapp verify",
    "verify:mobile": "pnpm --filter @scout/mobileapp verify",
    "verify:all": "pnpm run check:env && pnpm run check:packages && pnpm run verify:runtime-contract && pnpm run verify:web && pnpm run verify:desktop && pnpm run verify:mobile && pnpm run audit:maintainability && pnpm run budget:bundle",
    "doctor": "node ./scripts/doctor.mjs",
    "analyze:bundle": "node scripts/analyze-build.mjs",
    "budget:bundle": "node scripts/analyze-build.mjs --strict",
    "audit:maintainability": "node scripts/audit-maintainability.mjs --strict"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0"
  },
  "description": "Scout by Tenra is a market acquisition scanner for evidence-backed lead discovery and outreach handoffs."
}
