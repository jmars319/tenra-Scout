APP_NAME=Scout by Tenra
NODE_ENV=development

DATABASE_URL=postgresql:///scout
# Packaged macOS desktop can also read this from:
# ~/Library/Application Support/Scout by Tenra/.env

SCOUT_SEARCH_PROVIDER=duckduckgo_html
# Valid values: duckduckgo_html | google_html | bing_html | seeded_stub
# seeded_stub is reserved for verification only. Normal Scout runs should stay live-only.
SCOUT_SEARCH_API_KEY=
OPENAI_API_KEY=
SCOUT_OUTREACH_PROVIDER=local_template
# Valid values: local_template | ollama | openai | disabled
SCOUT_OUTREACH_MODEL=gpt-5-mini
SCOUT_OUTREACH_BASE_URL=http://127.0.0.1:11434
SCOUT_OUTREACH_DEFAULT_TONE=calm
SCOUT_OUTREACH_DEFAULT_LENGTH=standard

# Optional macOS public release signing/notarization.
# Keep real values out of git. `pnpm run package:desktop:release` requires
# Developer ID signing plus one notarization credential set.
# CSC_NAME=Developer ID Application: Your Name (TEAMID)
# APPLE_API_KEY=
# APPLE_API_KEY_ID=
# APPLE_API_ISSUER=
# APPLE_ID=
# APPLE_APP_SPECIFIC_PASSWORD=
# APPLE_TEAM_ID=
# APPLE_KEYCHAIN_PROFILE=
SCOUT_INTERACTIVE_SEARCH=0
SCOUT_INTERACTIVE_SEARCH_TIMEOUT_MS=180000
# Desktop mode enables interactive search automatically so blocked live providers can open
# a browser window for manual human confirmation.
# Optional advanced override:
# SCOUT_INTERACTIVE_SEARCH_PROFILE_DIR=

SCOUT_MIN_CANDIDATES=10
SCOUT_MAX_CANDIDATES=15
SCOUT_WORKER_POLL_MS=2000
SCOUT_WORKER_STALE_RUN_MS=2700000

EVIDENCE_STORAGE_DRIVER=local
EVIDENCE_LOCAL_DIR=./data/evidence

NEXT_PUBLIC_APP_URL=http://localhost:3000
